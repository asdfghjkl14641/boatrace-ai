# Supabase接続情報テンプレート
# このファイルをコピーして .env を作成し、本物の値を入れる
# .env はGitにコミットしないこと (.gitignoreで除外済み)

# --- Supabase Database接続 ---
# Supabaseダッシュボード → Project Settings → Database → Connection string → URI
# 例: postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:YOUR_DB_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# --- Supabase API (任意。使わなくてもOK) ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxxxxx

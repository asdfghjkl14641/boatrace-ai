# 環境変数テンプレート。このファイルをコピーして .env を作成する。
# .env はGitにコミットしない (.gitignoreで除外済み)。

# =====================================================
# DB切替: どのデータベースに読み書きするか
# =====================================================
# 'sqlite'   : プロジェクト直下の boatrace.db に保存 (デフォルト・推奨)
# 'supabase' : Supabase (PostgreSQL) に保存 (無料枠に注意)
DB_MODE=sqlite

# SQLite のファイルパス (DB_MODE=sqlite の時だけ使用、通常は既定でOK)
# SQLITE_PATH=C:/path/to/boatrace.db

# =====================================================
# Supabase 接続情報 (DB_MODE=supabase の時のみ必要)
# =====================================================
# Supabaseダッシュボード → Project Settings → Database → Connection string → URI (Transaction Pooler)
DATABASE_URL=postgresql://postgres.xxxx:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# =====================================================
# スクレイピング挙動
# =====================================================
# リクエスト間隔 (秒)。ブロックされたら 1.5〜2.0 に上げる。
FETCH_INTERVAL_SEC=0.8

# OpenAPI インポートのリクエスト間隔
OPENAPI_INTERVAL_SEC=0.3

# 公式LZH ダウンロード間隔
LZH_INTERVAL_SEC=0.5
